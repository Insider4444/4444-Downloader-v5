{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:5173",
    "distDir": "../dist",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "4444-Downloader",
    "version": "5.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "execute": true,
        "sidecar": true,
        "open": true,
        "scope": [
          {
            "name": "bin/yt-dlp",
            "sidecar": true,
            "args": true
          }
        ]
      },
      "fs": {
        "all": true,
        "scope": ["**"]
      },
      "dialog": {
        "all": true
      },
      "window": {
        "all": true
      },
      "path": {
        "all": true
      }
    },
    "bundle": {
      "icon": [
    "icons/32x32.png",
    "icons/128x128.png",
    "icons/128x128@2x.png",
    "icons/icon.icns",
    "icons/icon.ico"
    ],
      "active": true,
      "identifier": "com.bhargav.4444downloader",
      "externalBin": ["bin/yt-dlp"],
      "resources": ["bin/*"]
    },
   
    "windows": [
      {
        "fullscreen": false,
        "height": 780,
        "minHeight": 660,
        "minWidth": 760,
        "resizable": true,
        "title": "4444 Downloader (V5)",
        "visible": false,
        "width": 960,
        "center": true
      }
    ]
  }
}
